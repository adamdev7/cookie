# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cookie_orders

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

